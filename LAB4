    # Values and sample counts for the chosen split attribute
    attribute_counts = data[split_attribute].value_counts()
    total_samples = len(data)
    
    # Calculate weighted entropy after split
    weighted_entropy = 0
    for value, count in attribute_counts.items():
        # Subset where the attribute has the specific value
        subset = data[data[split_attribute] == value]
        subset_entropy = calculate_entropy(subset, target_col)
        
        # Weighted entropy contribution
        weight = count / total_samples
        weighted_entropy += weight * subset_entropy
        
