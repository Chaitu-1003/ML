# 3. Recursive ID3 Algorithm to build the tree
def id3_algorithm(data, original_data, features, target_col, parent_node_class=None):
    # Base Case 1: If data is empty, return the majority class of original data
    if len(data) == 0:
        return original_data[target_col].mode()[0]
    
    # Base Case 2: If the dataset is pure (only one class remains)
    if len(data[target_col].unique()) <= 1:
        return data[target_col].iloc[0]
    
    # Base Case 3: If no features are left to split on, return majority class
    if len(features) == 0:
        return data[target_col].mode()[0]
    
    # Find the feature that yields the maximum information gain
    gains = {feat: calculate_information_gain(data, feat, target_col) for feat in features}
    best_feature = max(gains, key=gains.get)
    
    # Initialize the tree node structure
    tree = {best_feature: {}}
    
    # Remove the chosen feature from the list for downstream branches
    remaining_features = [f for f in features if f != best_feature]
    
    # Grow the tree by branching on each unique value of the best feature
    unique_values = original_data[best_feature].unique()
    for value in unique_values:
        # Create a partition/subset based on the attribute value
        subset = data[data[best_feature] == value]
        
        # Recursively build subtrees
        subtree = id3_algorithm(
            data=subset,
            original_data=original_data,
            features=remaining_features,
            target_col=target_col,
            parent_node_class=data[target_col].mode()[0]
        )
        tree[best_feature][value] = subtree
        
    return tree    

    
